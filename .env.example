# NBV Resource Booking System - Environment Variables
# Copy this file to .env and update with your values

# Domain Configuration
DOMAIN=your-domain.com

# Node Environment (development/production)
NODE_ENV=production

# Database Configuration
DB_PATH=/data/db.json

# Port Configuration (if changing defaults)
# FRONTEND_PORT=3000
# BACKEND_PORT=3005
# NPM_ADMIN_PORT=81

# Nginx Proxy Manager Database Password
# Used for initial setup - change after first login
NPM_DB_PASSWORD=changeme

# Optional: Email for Let's Encrypt SSL certificates
LETSENCRYPT_EMAIL=admin@your-domain.com